{
  "name": "teramotors",
  "version": "1.0.0",
  "description": "TeraMotors Auto Repair Shop Management System",
  "scripts": {
    "build": "cd client && npm install && npm run build",
    "start": "cd client && npm install && npm run start",
    "dev": "cd client && npm run dev",
    "install-client": "cd client && npm install",
    "install-server": "cd server && npm install",
    "install-all": "npm run install-client && npm run install-server",
    "postinstall": "cd client && npm install",
    "install-puppeteer": "cd server && npx puppeteer browsers install chrome",
    "build-server": "cd server && npm install && npx puppeteer browsers install chrome",
    "cleanup-db": "node cleanup-database-mongo.js",
    "cleanup-db-dry": "node cleanup-database-mongo.js --dry-run",
    "cleanup-db-force": "node cleanup-database-mongo.js --confirm"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "auto-repair",
    "management",
    "nextjs",
    "mongodb"
  ],
  "author": "TeraMotors",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.25",
    "lint": "^0.8.19",
    "mongodb": "^6.20.0",
    "next": "^15.5.3",
    "react-countup": "^6.5.3",
    "react-day-picker": "^9.11.3",
    "react-intersection-observer": "^10.0.0",
    "recharts": "^3.5.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6"
  }
}
